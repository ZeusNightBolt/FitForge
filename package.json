{
  "name": "fitforge",
  "version": "0.1.0",
  "private": true,
  "description": "FitForge — a mobile-first personal-trainer + nutrition-guide MVP (Next.js + Supabase web, SwiftUI iOS, deterministic onboarding intelligence).",
  "license": "CC-BY-SA-4.0",
  "type": "module",
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "packageManager": "npm@10.8.2",
  "workspaces": [
    "apps/web",
    "packages/*",
    "seed"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "test:e2e": "npm run test:e2e -w @fitforge/web",
    "seed:check": "npm run seed:check -w @fitforge/seed",
    "seed:generate": "npm run seed:generate -w @fitforge/seed",
    "db:start": "supabase start",
    "db:reset": "supabase db reset",
    "db:test": "supabase test db",
    "clean": "turbo run clean && rimraf node_modules"
  },
  "devDependencies": {
    "rimraf": "^6.0.1",
    "turbo": "^2.1.2",
    "typescript": "^5.5.4"
  }
}
