# FitForge — environment template.
# Copy to `.env` (root) and/or `apps/web/.env.local` and fill in real values.
# NEVER commit real keys. Only the ANON key is safe to expose to browsers/clients.

# ---------------------------------------------------------------------------
# Supabase (public — safe for browser & iOS clients)
# ---------------------------------------------------------------------------
# Local dev defaults printed by `supabase start`:
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_ANON_KEY=your-local-anon-key

# The Next.js web app reads NEXT_PUBLIC_* variants (see apps/web/.env.example).
# Keep these in sync with the two above when running the web app.
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-local-anon-key
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ---------------------------------------------------------------------------
# Server-only secrets — NEVER expose to clients, NEVER prefix with NEXT_PUBLIC_
# ---------------------------------------------------------------------------
# Used only by the `delete-account` Edge Function and seeding/admin scripts.
# `supabase start` prints this as the "service_role key".
SUPABASE_SERVICE_ROLE_KEY=your-local-service-role-key
